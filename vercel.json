{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/(?!api).*$",
      "dest": "/frontend/dist/index.html",
      "status": 200
    },
    {
      "src": ".*",
      "dest": "/frontend/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
